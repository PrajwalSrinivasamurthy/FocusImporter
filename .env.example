# Copy this file to .env.local and fill in the values

# Local FastAPI proxy for Windows-Auth MSSQL access (pyodbc)
FOCUS_DB_PROXY_URL=http://127.0.0.1:8000/focus/query
INTERNAL_API_KEY=

# JWT signing secret — must be at least 32 characters
JWT_SECRET=

# Set to "true" to mark the session cookie Secure (requires HTTPS)
COOKIE_SECURE=false
