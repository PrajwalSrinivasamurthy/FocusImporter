# Copy this file to .env.local and fill in the values

# PostgreSQL (used by the postgres-db container)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=ttu_online_dev

# App's connection string to PostgreSQL.
# Use "localhost" when running the app outside Docker (postgres-db's port
# 5432 is published to the host). Use "postgres-db" as the host instead if
# the app is also run via docker-compose (same Docker network).
DATABASE_URL=postgresql://user:password@localhost:5432/ttu_online_dev

# JWT signing secret — must be at least 32 characters
JWT_SECRET=
